// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String            @id @default(uuid())
  email         String            @unique
  emailVerified DateTime?
  image         String?
  username      String            @unique
  passwordHash  String?
  name          String?
  role          Role              @default(USER)
  llmBaseUrl    String?
  llmApiKey     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  vocabularies  UserVocabulary[]
  grammarRules  UserGrammarRule[]
  sessions      Session[]
  accounts      Account[]
  cefrLevel     String            @default("A1")
  hasOnboarded  Boolean           @default(false)
  lastActive    DateTime          @default(now())
  theme         String            @default("default")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum Gender {
  der
  die
  das
}

model Vocabulary {
  id           String           @id @default(uuid())
  lemma        String
  meaning      String?
  partOfSpeech String?
  gender       Gender?
  plural       String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  users        UserVocabulary[]
}

model GrammarRule {
  id          String            @id @default(uuid())
  title       String
  description String?
  level       String            @default("A1")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  users       UserGrammarRule[]

  dependencies GrammarRule[] @relation("GrammarDependencies")
  dependents   GrammarRule[] @relation("GrammarDependencies")
}

enum SrsState {
  UNSEEN
  LEARNING
  KNOWN
  MASTERED
}

model UserVocabulary {
  id             String    @id @default(uuid())
  userId         String
  vocabularyId   String
  eloRating      Float     @default(1200)
  srsState       SrsState  @default(UNSEEN)
  nextReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
}

model UserGrammarRule {
  id             String    @id @default(uuid())
  userId         String
  grammarRuleId  String
  eloRating      Float     @default(1200)
  srsState       SrsState  @default(UNSEEN)
  nextReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  grammarRule GrammarRule @relation(fields: [grammarRuleId], references: [id], onDelete: Cascade)

  @@unique([userId, grammarRuleId])
}

model SiteSettings {
  id                String  @id @default("singleton")
  localLoginEnabled Boolean @default(true)
}
