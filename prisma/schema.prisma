// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model Language {
  id   String @id @default(uuid())
  code String @unique // e.g., 'de', 'es'
  name String // e.g., 'German', 'Spanish'
  flag String // e.g., '🇩🇪', '🇪🇸'

  vocabularies          Vocabulary[]
  grammarRules          GrammarRule[]
  userProgress          UserProgress[]
  activeUsers           User[]                 @relation("ActiveLanguage")
  immersionDestinations ImmersionDestination[]
}

// World-travel themed destinations for the Immersive Reading mode.
// Each destination gives the LLM a cultural + geographic anchor so generated
// content feels like authentic material from that place.
model ImmersionDestination {
  id          String   @id @default(uuid())
  languageId  String
  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  city        String // e.g., "Berlin"
  country     String // e.g., "Germany"
  emoji       String // flag emoji e.g., "🇩🇪"
  description String // short cultural note shown in the UI, e.g., "Germany's vibrant capital"
  createdAt   DateTime @default(now())

  @@index([languageId])
}

model User {
  id                   String                   @id @default(uuid())
  email                String                   @unique
  emailVerified        DateTime?
  image                String?
  username             String                   @unique
  passwordHash         String?
  name                 String?
  role                 Role                     @default(USER)
  useLocalLlm          Boolean                  @default(false)
  llmBaseUrl           String?
  llmApiKey            String?
  llmModel             String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  vocabularies         UserVocabulary[]
  vocabularyProgress   UserVocabularyProgress[]
  grammarRules         UserGrammarRule[]
  sessions             Session[]
  accounts             Account[]
  activeLanguageId     String?
  activeLanguage       Language?                @relation("ActiveLanguage", fields: [activeLanguageId], references: [id])
  progress             UserProgress[]
  classMembers         ClassMember[]
  assignmentScores     AssignmentScore[]
  liveSessions         LiveSessionParticipant[]
  conversationSessions ConversationSession[]

  // Deprecated: Moving to UserProgress
  // cefrLevel    String?  @default("A1")
  // hasOnboarded Boolean? @default(false)

  lastActive DateTime @default(now())
  theme      String   @default("default")

  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  totalXp          Int       @default(0)
  streakFreezes    Int       @default(0) // Purchasable streak shields
  timezone         String? // IANA timezone e.g. "America/New_York"

  createdGames        Game[]
  grammarRuleProgress UserGrammarRuleProgress[]
  levelUpEvents       LevelUpEvent[]
  reviewLogs          ReviewLog[]

  localLoadTimeSamples  Int[]         @default([])
  aiUsage               UserAiUsage[]
  fsrsRetention         Float         @default(0.9) // FSRS target retention [0.7, 0.97]
  fsrsWeights           Float[]       @default([]) // Per-user optimized FSRS-5 weights (19 values); empty = use global defaults
  sessionSuccessEma     Float         @default(0.75) // EMA of per-session correct rate [0,1]; drives adaptive new-word cap
  interleaveBanditState String? // JSON: {arms:[{alpha,beta}]} for Thompson-sampling interleave count (0..MAX_INTERLEAVE)
}

model UserProgress {
  id           String   @id @default(uuid())
  userId       String
  languageId   String
  cefrLevel    String   @default("A1")
  hasOnboarded Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([userId, languageId])
  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum Gender {
  MASCULINE
  FEMININE
  NEUTER
}

model Vocabulary {
  id              String                   @id @default(uuid())
  languageId      String?
  language        Language?                @relation(fields: [languageId], references: [id])
  lemma           String
  meanings        Meaning[]
  partOfSpeech    String?
  gender          Gender?
  plural          String?
  metadata        Json?
  isBeginner      Boolean                  @default(false)
  cefrLevel       String                   @default("A1")
  isAutoGenerated Boolean                  @default(false)
  frequency       Int? // corpus rank: 1 = most frequent, null = not in frequency DB
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  users           UserVocabulary[]
  progress        UserVocabularyProgress[]

  @@index([lemma])
}

model Meaning {
  id           String     @id @default(uuid())
  vocabularyId String
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  value        String
  partOfSpeech String?
  context      String?

  @@index([value])
}

model GrammarRule {
  id          String                    @id @default(uuid())
  languageId  String?
  language    Language?                 @relation(fields: [languageId], references: [id])
  title       String
  description String?
  guide       String?
  level       String                    @default("A1")
  ruleType    String? // snake_case category e.g. "case_marking", "verb_conjugation"
  targetForms String[] // surface forms the LLM should produce e.g. ["den", "einen"]
  pfaGamma    Float? // PFA: baseline log-odds of correctness (higher = easier rule globally)
  pfaRho      Float? // PFA: learning rate per successful attempt
  pfaDelta    Float? // PFA: forgetting rate per failed attempt
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  users       UserGrammarRule[]
  progress    UserGrammarRuleProgress[]

  dependencies GrammarRule[] @relation("GrammarDependencies")
  dependents   GrammarRule[] @relation("GrammarDependencies")
}

enum SrsState {
  UNSEEN
  LEARNING
  KNOWN
  MASTERED
}

model UserVocabulary {
  id             String    @id @default(uuid())
  userId         String
  vocabularyId   String
  eloRating      Float     @default(1200)
  eloVariance    Float     @default(400) // Bayesian ELO: initial variance σ² (σ≈20 → high uncertainty)
  srsState       SrsState  @default(UNSEEN)
  nextReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@index([userId, srsState, nextReviewDate])
}

model UserVocabularyProgress {
  id               String    @id @default(uuid())
  userId           String
  vocabularyId     String
  nextReviewDate   DateTime
  difficulty       Float     @default(5.0) // FSRS: [1, 10]
  stability        Float     @default(0.0) // FSRS: days until 90% forgetting
  retrievability   Float     @default(1.0) // FSRS: current memory strength [0, 1]
  repetitions      Int       @default(0)
  lapses           Int       @default(0)
  overrideCount    Int       @default(0) // times user overrode an incorrect grade to correct
  lastErrorType    String? // most recent structured error category, null when last answer was correct
  errorCounts      String? // JSON: decayed error-type count vector {wrong_case:1.2, spelling:0.7, ...}
  lastReviewDate   DateTime?
  medianResponseMs Int? // running median response time in ms (updated each review)
  reviewCount      Int       @default(0) // total reviews — used to update running median
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@index([userId, nextReviewDate])
  @@index([nextReviewDate])
}

model UserGrammarRule {
  id             String    @id @default(uuid())
  userId         String
  grammarRuleId  String
  eloRating      Float     @default(1200)
  eloVariance    Float     @default(400) // Bayesian ELO: initial variance σ² (σ≈20 → high uncertainty)
  srsState       SrsState  @default(UNSEEN)
  nextReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  grammarRule GrammarRule @relation(fields: [grammarRuleId], references: [id], onDelete: Cascade)

  @@unique([userId, grammarRuleId])
  @@index([userId, srsState, nextReviewDate])
}

model UserGrammarRuleProgress {
  id               String    @id @default(uuid())
  userId           String
  grammarRuleId    String
  nextReviewDate   DateTime
  difficulty       Float     @default(5.0) // FSRS: [1, 10]
  stability        Float     @default(0.0) // FSRS: days until 90% forgetting
  retrievability   Float     @default(1.0) // FSRS: current memory strength [0, 1]
  repetitions      Int       @default(0)
  lapses           Int       @default(0)
  lastErrorType    String? // most recent structured error category, null when last answer was correct
  errorCounts      String? // JSON: decayed error-type count vector {wrong_case:1.2, spelling:0.7, ...}
  lastReviewDate   DateTime?
  medianResponseMs Int? // running median response time in ms
  reviewCount      Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  grammarRule GrammarRule @relation(fields: [grammarRuleId], references: [id], onDelete: Cascade)

  @@unique([userId, grammarRuleId])
  @@index([userId, nextReviewDate])
  @@index([nextReviewDate])
}

// Per-review event log used by the FSRS weight optimizer and HLR fitter.
// Rows are pruned to a 1-year rolling window by the maintenance job.
// Longer history lets the optimizer converge on mature cards with multi-month
// intervals that would be invisible inside a 30-day window.
model ReviewLog {
  id             String   @id @default(uuid())
  userId         String
  itemId         String // vocabularyId or grammarRuleId
  itemType       String // 'vocabulary' | 'grammar'
  rating         Int // FSRS rating 1-4 (Again/Hard/Good/Easy)
  elapsedDays    Float // days since last review of this item
  scheduledDays  Float // interval that was scheduled (0 for first review)
  stability      Float // stability before this review
  difficulty     Float // difficulty before this review
  responseTimeMs Int? // ms from question render to submission (null = not collected)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt]) // for bulk pruning by date
}

model LevelUpEvent {
  id             String   @id @default(uuid())
  userId         String
  languageId     String
  oldLevel       String
  newLevel       String
  vocabMastery   Float
  grammarMastery Float
  averageElo     Float
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, languageId])
}

model SiteSettings {
  id                   String    @id @default("singleton")
  localLoginEnabled    Boolean   @default(true)
  loadTimeSamples      Int[]
  localLoadTimeSamples Int[]     @default([])
  llmEndpoint          String?
  llmModel             String?
  llmApiKey            String?
  hlrWeights           String? // JSON-encoded HlrWeights (fitted daily by maintenance)
  pfaUpdatedAt         DateTime? // last time PFA params were fitted
  errorCoMatrix        String? // JSON-encoded error co-occurrence matrix {[typeA]:{[typeB]:count}}
}

enum ClassRole {
  TEACHER
  STUDENT
}

model Class {
  id              String   @id @default(uuid())
  name            String
  description     String?
  inviteCode      String   @unique
  primaryLanguage String   @default("international")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members      ClassMember[]
  assignments  Assignment[]
  liveSessions LiveSession[]
}

model LiveSession {
  id                   String   @id @default(uuid())
  classId              String
  gameId               String
  status               String   @default("waiting") // waiting, active, finished
  currentQuestionIndex Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  class        Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  game         Game                     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  participants LiveSessionParticipant[]

  @@index([classId])
  @@index([gameId])
}

model Game {
  id          String   @id @default(uuid())
  title       String
  description String?
  language    String
  creatorId   String
  isPublished Boolean  @default(false)
  category    String   @default("General")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator      User           @relation(fields: [creatorId], references: [id])
  questions    GameQuestion[]
  liveSessions LiveSession[]
  assignments  Assignment[]
}

model GameQuestion {
  id        String   @id @default(uuid())
  gameId    String
  question  String
  answer    String
  options   Json? // Runtime type: string[] | null — multiple-choice answer options
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
}

model LiveSessionParticipant {
  id          String   @id @default(uuid())
  sessionId   String
  userId      String
  score       Int      @default(0)
  hasAnswered Boolean  @default(false)
  joinedAt    DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model ClassMember {
  id        String    @id @default(uuid())
  classId   String
  userId    String
  role      ClassRole @default(STUDENT)
  createdAt DateTime  @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([classId])
  @@index([userId])
}

model Assignment {
  id                      String    @id @default(uuid())
  classId                 String
  title                   String
  description             String?
  gamemode                String
  gameId                  String?
  language                String
  targetScore             Int
  passThreshold           Int       @default(50)
  targetCefrLevel         String?
  dueDate                 DateTime?
  topic                   String?
  targetGrammar           String[]
  targetVocab             String[]
  disableHoverTranslation Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  class  Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  game   Game?             @relation(fields: [gameId], references: [id], onDelete: SetNull)
  scores AssignmentScore[]
}

model AssignmentScore {
  id           String   @id @default(uuid())
  assignmentId String
  userId       String
  score        Int
  passed       Boolean  @default(false)
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
}

// Tracks daily AI token consumption per user.
// tokensUsed is incremented for every public-LLM call. goodWillTokens is
// incremented when a call benefits the shared database (e.g. enriching or
// creating vocabulary that was persisted) — these are refunded so they don't
// count against the user's daily budget.
// Effective daily usage = tokensUsed - goodWillTokens.
model UserAiUsage {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime // UTC date (time portion zeroed to midnight)
  tokensUsed     Int      @default(0)
  goodWillTokens Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model ConversationSession {
  id           String   @id @default(uuid())
  userId       String
  language     String
  persona      String
  assignmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id         String   @id @default(uuid())
  sessionId  String
  role       String // 'user' or 'assistant'
  content    String   @db.Text
  correction String?  @db.Text
  createdAt  DateTime @default(now())

  session ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
