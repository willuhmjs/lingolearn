// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model Language {
  id   String @id @default(uuid())
  code String @unique // e.g., 'de', 'es'
  name String // e.g., 'German', 'Spanish'
  flag String // e.g., '🇩🇪', '🇪🇸'

  vocabularies Vocabulary[]
  grammarRules GrammarRule[]
  userProgress UserProgress[]
  activeUsers  User[]         @relation("ActiveLanguage")
}

model User {
  id                   String                   @id @default(uuid())
  email                String                   @unique
  emailVerified        DateTime?
  image                String?
  username             String                   @unique
  passwordHash         String?
  name                 String?
  role                 Role                     @default(USER)
  useLocalLlm          Boolean                  @default(false)
  llmBaseUrl           String?
  llmApiKey            String?
  llmModel             String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  vocabularies         UserVocabulary[]
  vocabularyProgress   UserVocabularyProgress[]
  grammarRules         UserGrammarRule[]
  sessions             Session[]
  accounts             Account[]
  activeLanguageId     String?
  activeLanguage       Language?                @relation("ActiveLanguage", fields: [activeLanguageId], references: [id])
  progress             UserProgress[]
  classMembers         ClassMember[]
  assignmentScores     AssignmentScore[]
  liveSessions         LiveSessionParticipant[]
  conversationSessions ConversationSession[]

  // Deprecated: Moving to UserProgress
  // cefrLevel    String?  @default("A1")
  // hasOnboarded Boolean? @default(false)

  lastActive DateTime @default(now())
  theme      String   @default("default")

  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  totalXp          Int       @default(0)
  streakFreezes    Int       @default(0) // Purchasable streak shields
  timezone         String?   // IANA timezone e.g. "America/New_York"

  createdGames          Game[]
  grammarRuleProgress   UserGrammarRuleProgress[]
  levelUpEvents         LevelUpEvent[]
}

model UserProgress {
  id           String   @id @default(uuid())
  userId       String
  languageId   String
  cefrLevel    String   @default("A1")
  hasOnboarded Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([userId, languageId])
  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum Gender {
  MASCULINE
  FEMININE
  NEUTER
}

model Vocabulary {
  id              String                   @id @default(uuid())
  languageId      String?
  language        Language?                @relation(fields: [languageId], references: [id])
  lemma           String
  meanings        Meaning[]
  partOfSpeech    String?
  gender          Gender?
  plural          String?
  metadata        Json?
  isBeginner      Boolean                  @default(false)
  cefrLevel       String                   @default("A1")
  isAutoGenerated Boolean                  @default(false)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  users           UserVocabulary[]
  progress        UserVocabularyProgress[]

  @@index([lemma])
}

model Meaning {
  id           String     @id @default(uuid())
  vocabularyId String
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  value        String
  partOfSpeech String?
  context      String?

  @@index([value])
}

model GrammarRule {
  id          String            @id @default(uuid())
  languageId  String?
  language    Language?         @relation(fields: [languageId], references: [id])
  title       String
  description String?
  guide       String?
  level       String            @default("A1")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  users    UserGrammarRule[]
  progress UserGrammarRuleProgress[]

  dependencies GrammarRule[] @relation("GrammarDependencies")
  dependents   GrammarRule[] @relation("GrammarDependencies")
}

enum SrsState {
  UNSEEN
  LEARNING
  KNOWN
  MASTERED
}

model UserVocabulary {
  id             String    @id @default(uuid())
  userId         String
  vocabularyId   String
  eloRating      Float     @default(1200)
  srsState       SrsState  @default(UNSEEN)
  nextReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@index([userId, srsState, nextReviewDate])
}

model UserVocabularyProgress {
  id             String    @id @default(uuid())
  userId         String
  vocabularyId   String
  nextReviewDate DateTime
  difficulty     Float     @default(5.0) // FSRS: [1, 10]
  stability      Float     @default(0.0) // FSRS: days until 90% forgetting
  retrievability Float     @default(1.0) // FSRS: current memory strength [0, 1]
  repetitions    Int       @default(0)
  lapses         Int       @default(0)
  lastReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@index([nextReviewDate])
}

model UserGrammarRule {
  id             String    @id @default(uuid())
  userId         String
  grammarRuleId  String
  eloRating      Float     @default(1200)
  srsState       SrsState  @default(UNSEEN)
  nextReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  grammarRule GrammarRule @relation(fields: [grammarRuleId], references: [id], onDelete: Cascade)

  @@unique([userId, grammarRuleId])
  @@index([userId, srsState, nextReviewDate])
}

model UserGrammarRuleProgress {
  id             String    @id @default(uuid())
  userId         String
  grammarRuleId  String
  nextReviewDate DateTime
  difficulty     Float     @default(5.0) // FSRS: [1, 10]
  stability      Float     @default(0.0) // FSRS: days until 90% forgetting
  retrievability Float     @default(1.0) // FSRS: current memory strength [0, 1]
  repetitions    Int       @default(0)
  lapses         Int       @default(0)
  lastReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  grammarRule GrammarRule @relation(fields: [grammarRuleId], references: [id], onDelete: Cascade)

  @@unique([userId, grammarRuleId])
  @@index([nextReviewDate])
}

model LevelUpEvent {
  id              String   @id @default(uuid())
  userId          String
  languageId      String
  oldLevel        String
  newLevel        String
  vocabMastery    Float
  grammarMastery  Float
  averageElo      Float
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, languageId])
}

model SiteSettings {
  id                    String  @id @default("singleton")
  localLoginEnabled     Boolean @default(true)
  loadTimeSamples       Int[]
  localLoadTimeSamples  Int[]   @default([])
  llmEndpoint           String?
  llmModel              String?
  llmApiKey             String?
}

enum ClassRole {
  TEACHER
  STUDENT
}

model Class {
  id              String   @id @default(uuid())
  name            String
  description     String?
  inviteCode      String   @unique
  primaryLanguage String   @default("international")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members      ClassMember[]
  assignments  Assignment[]
  liveSessions LiveSession[]
}

model LiveSession {
  id                   String   @id @default(uuid())
  classId              String
  gameId               String
  status               String   @default("waiting") // waiting, active, finished
  currentQuestionIndex Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  class        Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  game         Game                     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  participants LiveSessionParticipant[]

  @@index([classId])
  @@index([gameId])
}

model Game {
  id          String   @id @default(uuid())
  title       String
  description String?
  language    String
  creatorId   String
  isPublished Boolean  @default(false)
  category    String   @default("General")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator      User           @relation(fields: [creatorId], references: [id])
  questions    GameQuestion[]
  liveSessions LiveSession[]
}

model GameQuestion {
  id        String   @id @default(uuid())
  gameId    String
  question  String
  answer    String
  options   Json?
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
}

model LiveSessionParticipant {
  id          String   @id @default(uuid())
  sessionId   String
  userId      String
  score       Int      @default(0)
  hasAnswered Boolean  @default(false)
  joinedAt    DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model ClassMember {
  id        String    @id @default(uuid())
  classId   String
  userId    String
  role      ClassRole @default(STUDENT)
  createdAt DateTime  @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([classId])
  @@index([userId])
}

model Assignment {
  id              String    @id @default(uuid())
  classId         String
  title           String
  description     String?
  gamemode        String
  language        String
  targetScore     Int
  passThreshold   Int       @default(50)
  targetCefrLevel String?
  dueDate         DateTime?
  topic           String?
  targetGrammar   String[]
  targetVocab     String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  class  Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  scores AssignmentScore[]
}

model AssignmentScore {
  id           String   @id @default(uuid())
  assignmentId String
  userId       String
  score        Int
  passed       Boolean  @default(false)
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
}

model ConversationSession {
  id           String   @id @default(uuid())
  userId       String
  language     String
  persona      String
  assignmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id         String   @id @default(uuid())
  sessionId  String
  role       String // 'user' or 'assistant'
  content    String   @db.Text
  correction String?  @db.Text
  createdAt  DateTime @default(now())

  session ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
